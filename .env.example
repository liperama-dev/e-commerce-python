# .env.example — copy to .env and fill in real values before running docker-compose
ADMIN_SECRET_KEY=changeme
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# DATABASE_URL is set automatically inside the Docker container by entrypoint.sh.
# Override here only when running outside Docker:
# DATABASE_URL=sqlite:///./ecommerce.db

# TESTING — do NOT set this in .env.
# This flag is injected exclusively by pytest (via pytest.ini) to:
#   1. Prevent the lifespan from seeding the database during test runs.
#   2. Enable the GET /api/auth/hint endpoint, which returns default admin
#      credentials so the frontend can display a helpful sign-in tip.
# Setting TESTING=true in a real deployment would expose the hint endpoint
# and suppress database seeding on startup, so leave it unset in production.
